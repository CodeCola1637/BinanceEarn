# ═══════════════════════════════════════════════
#  BinanceEarn 配置文件
# ═══════════════════════════════════════════════

# ── 币安 API 凭证 ──────────────────────────────
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# ── Earn 策略参数 ──────────────────────────────
# 最小锁仓 BNB 数量（低于此值不操作）
BN_MIN_SUBSCRIBE_BNB=0.01
# 保留在现货的 BNB 数量（不全部锁入，留一点灵活用）
BN_RESERVE_BNB=0.005
# 是否自动卖出空投代币（true=上线即卖，false=持有）
BN_AUTO_SELL_AIRDROP=false

# ── 监控频率 ──────────────────────────────────
# Launchpool 扫描间隔（秒）
BN_LAUNCHPOOL_SCAN_INTERVAL=600
# 空投检查间隔（秒）
BN_AIRDROP_CHECK_INTERVAL=3600
# 余额快照间隔（秒）
BN_BALANCE_SNAPSHOT_INTERVAL=300

# ── Dashboard ─────────────────────────────────
# Web 看板端口
DASHBOARD_PORT=8080
