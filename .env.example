# ═══════════════════════════════════════════════
#  BinanceEarn 配置文件（模式 A：完全无人值守）
# ═══════════════════════════════════════════════

# ── 币安 API 凭证 ──────────────────────────────
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# ── 锁仓参数 ──────────────────────────────────
# 最小锁仓 BNB 数量（低于此值不操作）
BN_MIN_SUBSCRIBE_BNB=0.01
# 保留在现货的 BNB 数量（不全部锁入）
BN_RESERVE_BNB=0.005
# 空投代币自动卖出（true=检测到即卖，false=仅记录）
BN_AUTO_SELL_AIRDROP=true
# 卖出所得自动买 BNB 复利（true=自动复投）
BN_AUTO_COMPOUND=false

# ── 检查频率（秒） ────────────────────────────
# BNB 锁仓检查间隔
BN_EARN_CHECK_INTERVAL=300
# 空投检测间隔
BN_AIRDROP_CHECK_INTERVAL=1800
# 公告扫描间隔
BN_ANNOUNCE_CHECK_INTERVAL=1800
# 状态文件写入间隔
BN_STATE_WRITE_INTERVAL=30

# ── Dashboard ─────────────────────────────────
DASHBOARD_PORT=8080
